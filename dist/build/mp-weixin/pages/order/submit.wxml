<view class="container"><view class="nav-bar"><button class="nav-back" bindtap="{{a}}">← 返回</button><text class="nav-title">确认订单</text><view class="nav-placeholder"></view></view><view class="content"><view class="section"><view class="section-title">📝 备注信息</view><view class="form"><block wx:if="{{r0}}"><textarea placeholder="如：忌口、辣度、取餐方式等" maxlength="100" value="{{b}}" bindinput="{{c}}"/></block><text class="char-count">{{d}}/100</text></view></view><view class="section"><view class="section-title">🛒 订单明细</view><view class="order-list"><view wx:for="{{e}}" wx:for-item="item" wx:key="f" class="order-item"><image src="{{item.a}}" class="item-img" mode="aspectFill"/><view class="item-info"><text class="item-name">{{item.b}}</text><text class="item-price">¥{{item.c}}</text></view><view class="item-right"><text class="item-qty">x{{item.d}}</text><text class="item-subtotal">¥{{item.e}}</text></view></view></view></view><view class="section total-section"><view class="total-row"><text>商品总价</text><text class="total-amount">¥{{f}}</text></view></view></view><view class="bottom-bar"><view class="total-info"><text class="total-label">合计</text><text class="total-price">¥{{g}}</text></view><button class="btn-submit" disabled="{{i}}" bindtap="{{j}}"><text wx:if="{{h}}">提交订单</text><text wx:else>提交中...</text></button></view><view wx:if="{{k}}" class="success-modal"><view class="success-content"><text class="success-icon">✓</text><text class="success-title">下单成功</text><text class="success-order">订单号：{{l}}</text><text class="success-tip">请留意订单制作进度</text><button class="btn-confirm" bindtap="{{m}}">查看订单</button></view></view></view>