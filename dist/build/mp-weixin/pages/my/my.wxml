<view class="container"><view class="header"><view class="avatar"><text>🌮</text></view><view class="info"><text class="nickname">{{a}}</text><text class="phone">{{b}}</text></view></view><view class="section"><view class="section-title">📋 我的订单</view><view wx:if="{{c}}" class="loading"><text>加载中...</text></view><view wx:elif="{{d}}" class="empty"><text class="empty-icon">📋</text><text>暂无订单</text><text class="empty-hint">快去下单吧～</text></view><view wx:else class="order-list"><view wx:for="{{e}}" wx:for-item="order" wx:key="g" class="{{['order-card', order.h && 'order-expired']}}"><view class="order-header"><text class="order-no">#{{order.a}}</text><text class="{{['status', order.c]}}">{{order.b}}</text></view><view class="order-items"><view wx:for="{{order.d}}" wx:for-item="item" wx:key="c" class="order-item"><text class="item-name">{{item.a}}</text><text class="item-qty">x{{item.b}}</text></view></view><view class="order-footer"><text class="order-time">{{order.e}}</text><text class="total">¥{{order.f}}</text></view></view></view></view><view class="menu-list"><button class="menu-btn" bindtap="{{f}}"><view class="menu-left"><text class="menu-icon">ℹ️</text><text class="menu-text">关于我们</text></view><text class="menu-arrow">›</text></button><button class="menu-btn" bindtap="{{g}}"><view class="menu-left"><text class="menu-icon">🚪</text><text class="menu-text logout">退出登录</text></view><text class="menu-arrow">›</text></button></view><view class="footer"><text>街头塔可 v1.0.0</text></view></view>