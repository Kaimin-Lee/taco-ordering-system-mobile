<view class="container"><view class="header"><text class="shop-name">🌮 街头塔可</text><text class="status">营业中</text></view><view class="menu"><view class="category-nav"><view wx:for="{{a}}" wx:for-item="cat" wx:key="b" class="{{['cat-item', cat.c]}}" bindtap="{{cat.d}}">{{cat.a}}</view></view><view class="product-list"><view wx:for="{{b}}" wx:for-item="p" wx:key="j" class="product-card"><image src="{{p.a}}" class="product-img" mode="aspectFill"/><view class="product-info"><text class="product-name">{{p.b}}</text><text class="product-desc">{{p.c}}</text><view class="product-bottom"><text class="price">¥{{p.d}}</text><view class="counter"><view wx:if="{{p.e}}" class="btn-counter btn-minus" bindtap="{{p.f}}">-</view><text wx:if="{{p.g}}" class="count">{{p.h}}</text><view class="btn-counter btn-plus" bindtap="{{p.i}}">+</view></view></view></view></view></view></view><view class="cart-bar" bindtap="{{h}}"><view class="cart-icon"><text class="cart-icon-text">🛒</text><text wx:if="{{c}}" class="cart-badge">{{d}}</text></view><view class="cart-info"><text class="cart-amount">¥{{e}}</text></view><view catchtap="{{f}}" class="{{['btn-submit', g && 'disabled']}}"><text>去结算</text></view></view><view wx:if="{{i}}" class="cart-modal" bindtap="{{n}}"><view class="cart-content" catchtap="{{m}}"><view class="cart-header"><text class="cart-title">购物车</text><text class="cart-clear" bindtap="{{j}}">清空</text></view><view class="cart-items"><view wx:for="{{k}}" wx:for-item="item" wx:key="g" class="cart-item"><image src="{{item.a}}" class="cart-item-img" mode="aspectFill"/><view class="cart-item-info"><text class="cart-item-name">{{item.b}}</text><text class="cart-item-price">¥{{item.c}}</text></view><view class="cart-item-counter"><view class="btn-counter btn-minus" bindtap="{{item.d}}">-</view><text class="count">{{item.e}}</text><view class="btn-counter btn-plus" bindtap="{{item.f}}">+</view></view></view><view wx:if="{{l}}" class="cart-empty"><text>购物车空空如也~</text></view></view></view></view></view>