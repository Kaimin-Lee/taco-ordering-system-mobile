<view class="container"><view class="header"><text class="shop-name">街头塔可</text><text class="status">营业中</text></view><view class="menu"><view class="category-nav"><view wx:for="{{a}}" wx:for-item="cat" wx:key="b" class="{{['cat-item', cat.c]}}" bindtap="{{cat.d}}">{{cat.a}}</view></view><scroll-view class="product-list" scroll-y><view wx:for="{{b}}" wx:for-item="cat" wx:key="b" hidden="{{!cat.c}}"><view wx:for="{{cat.a}}" wx:for-item="p" wx:key="j" class="product-item"><image src="{{p.a}}" class="product-img" mode="aspectFill"/><view class="product-info"><text class="product-name">{{p.b}}</text><text class="product-desc">{{p.c}}</text><view class="product-bottom"><text class="price">¥{{p.d}}</text><view class="counter"><button wx:if="{{p.e}}" class="btn-minus" bindtap="{{p.f}}">-</button><text wx:if="{{p.g}}" class="count">{{p.h}}</text><button class="btn-plus" bindtap="{{p.i}}">+</button></view></view></view></view></view></scroll-view></view><view class="cart-bar" bindtap="{{f}}"><view class="cart-info"><text class="cart-count">{{c}}</text><text class="cart-amount">¥{{d}}</text></view><button class="btn-submit" catchtap="{{e}}">去结算</button></view><view wx:if="{{g}}" class="cart-modal" bindtap="{{k}}"><view class="cart-content" catchtap="{{j}}"><view class="cart-header"><text>购物车</text><text bindtap="{{h}}">清空</text></view><view wx:for="{{i}}" wx:for-item="item" wx:key="e" class="cart-item"><text>{{item.a}}</text><view class="counter"><button class="btn-minus" bindtap="{{item.b}}">-</button><text class="count">{{item.c}}</text><button class="btn-plus" bindtap="{{item.d}}">+</button></view></view></view></view></view>