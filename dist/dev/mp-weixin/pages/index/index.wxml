<view class="container"><view class="header"><text class="shop-name">🌮 街头塔可</text><text class="status">营业中</text></view><view class="menu"><view class="category-nav"><view wx:for="{{a}}" wx:for-item="cat" wx:key="b" class="{{['cat-item', cat.c]}}" bindtap="{{cat.d}}">{{cat.a}}</view></view><scroll-view class="product-scroll" scroll-y scroll-into-view="{{c}}" scroll-with-animation bindscroll="{{d}}"><view wx:for="{{b}}" wx:for-item="cat" wx:key="c" id="{{cat.d}}" class="{{['category-section', cat.e]}}"><view class="category-header"><text class="category-name">{{cat.a}}</text></view><view class="product-list"><view wx:for="{{cat.b}}" wx:for-item="p" wx:key="j" class="product-card"><image src="{{p.a}}" class="product-img" mode="aspectFill"/><view class="product-info"><text class="product-name">{{p.b}}</text><text class="product-desc">{{p.c}}</text><view class="product-bottom"><text class="price">¥{{p.d}}</text><view class="counter"><view wx:if="{{p.e}}" class="btn-counter btn-minus" bindtap="{{p.f}}">-</view><text wx:if="{{p.g}}" class="count">{{p.h}}</text><view class="btn-counter btn-plus" bindtap="{{p.i}}">+</view></view></view></view></view></view></view><view class="bottom-space"></view></scroll-view></view><view class="cart-bar" bindtap="{{j}}"><view class="cart-icon"><text class="cart-icon-text">🛒</text><text wx:if="{{e}}" class="cart-badge">{{f}}</text></view><view class="cart-info"><text class="cart-amount">¥{{g}}</text></view><view catchtap="{{h}}" class="{{['btn-submit', i && 'disabled']}}"><text>去结算</text></view></view><view wx:if="{{k}}" class="cart-modal" bindtap="{{p}}"><view class="cart-content" catchtap="{{o}}"><view class="cart-header"><text class="cart-title">购物车</text><text class="cart-clear" bindtap="{{l}}">清空</text></view><view class="cart-items"><view wx:for="{{m}}" wx:for-item="item" wx:key="g" class="cart-item"><image src="{{item.a}}" class="cart-item-img" mode="aspectFill"/><view class="cart-item-info"><text class="cart-item-name">{{item.b}}</text><text class="cart-item-price">¥{{item.c}}</text></view><view class="cart-item-counter"><view class="btn-counter btn-minus" bindtap="{{item.d}}">-</view><text class="count">{{item.e}}</text><view class="btn-counter btn-plus" bindtap="{{item.f}}">+</view></view></view><view wx:if="{{n}}" class="cart-empty"><text>购物车空空如也~</text></view></view></view></view></view>