<view class="container"><view class="nav-bar"><button class="nav-back" bindtap="{{a}}"><text>返回</text></button><text class="nav-title">订单详情</text><view class="nav-placeholder"></view></view><view wx:if="{{b}}" class="loading"><text>加载中...</text></view><view wx:elif="{{c}}" class="content"><view class="order-header"><view class="order-no"><text>订单号：</text><text>{{d}}</text></view><view class="{{['status', f]}}">{{e}}</view></view><view class="order-items"><view class="section-title"><text>商品详情</text></view><view wx:for="{{g}}" wx:for-item="item" wx:key="d" class="order-item"><view class="item-name"><text>{{item.a}}</text></view><view class="item-info"><text>¥{{item.b}}</text><text>×{{item.c}}</text></view></view></view><view wx:if="{{h}}" class="remark-section"><view class="section-title"><text>备注</text></view><text class="remark">{{i}}</text></view><view class="price-section"><text>实付金额</text><text class="total">¥{{j}}</text></view><view class="time-section"><text>下单时间</text><text>{{k}}</text></view></view></view>