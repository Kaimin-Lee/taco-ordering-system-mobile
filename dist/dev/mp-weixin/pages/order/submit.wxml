<view class="container"><view class="form"><view class="form-item"><text class="label">桌号/取餐号</text><input placeholder="请输入桌号" value="{{a}}" bindinput="{{b}}"/></view><view class="form-item"><text class="label">备注</text><block wx:if="{{r0}}"><textarea placeholder="忌口、辣度等" value="{{c}}" bindinput="{{d}}"/></block></view></view><view class="order-list"><view wx:for="{{e}}" wx:for-item="item" wx:key="d" class="order-item"><text>{{item.a}}</text><text>x{{item.b}}</text><text>¥{{item.c}}</text></view></view><view class="total"><text>总计：</text><text class="amount">¥{{f}}</text></view><button class="btn-submit" bindtap="{{g}}">提交订单</button></view>