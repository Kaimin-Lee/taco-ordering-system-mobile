<view class="container"><view wx:if="{{a}}" class="empty"><text>暂无订单</text></view><view wx:for="{{b}}" wx:for-item="order" wx:key="g" class="order-card"><view class="order-header"><text>订单号：{{order.a}}</text><text class="{{['status', order.c]}}">{{order.b}}</text></view><view wx:for="{{order.d}}" wx:for-item="item" wx:key="d" class="order-item"><text>{{item.a}}</text><text>x{{item.b}}</text><text>¥{{item.c}}</text></view><view class="order-footer"><text>桌号：{{order.e}}</text><text class="total">合计：¥{{order.f}}</text></view></view></view>